"use server";

import { HfInference } from "@huggingface/inference";

export async function analyzePlantImage(imageBase64: string, apiKey?: string) {
    try {
        const hf = new HfInference(apiKey);

        // Remove header if present
        const base64Data = imageBase64.split(",")[1] || imageBase64;

        // Convert base64 to blob
        const binaryString = atob(base64Data);
        const bytes = new Uint8Array(binaryString.length);
        for (let i = 0; i < binaryString.length; i++) {
            bytes[i] = binaryString.charCodeAt(i);
        }
        const blob = new Blob([bytes], { type: "image/jpeg" });

        // Use image classification to detect plant health
        // Using google/vit-base-patch16-224 - available on free tier
        let classificationResult;
        try {
            classificationResult = await hf.imageClassification({
                model: "google/vit-base-patch16-224",
                data: blob,
            });
        } catch (visionError: any) {
            // If vision model fails, provide a generic analysis
            console.warn("Vision model unavailable:", visionError);
            return {
                disease: "Analysis Unavailable",
                confidence: 0,
                description: "Image analysis is temporarily unavailable. The vision model is loading or rate-limited. Please try again in a few moments.",
                treatment: ["Wait 10-20 seconds and try again", "Ensure image is clear and well-lit", "Consider adding a Hugging Face API key for better availability"]
            };
        }

        // Get top classification
        const topClass = classificationResult[0];
        const imageDescription = topClass?.label || "unknown plant";
        const confidence = Math.round((topClass?.score || 0.5) * 100);

        // Use chat model to analyze based on classification
        const prompt = `Based on this plant image classification: "${imageDescription}"

Analyze for potential plant diseases or health issues. Return ONLY a JSON object with this exact structure:
{
  "disease": "Name of the disease or 'Healthy'",
  "confidence": ${confidence},
  "description": "Brief explanation of the issue (2 sentences max)",
  "treatment": ["Step 1", "Step 2", "Step 3"]
}

Return ONLY the JSON object, no other text.`;

        const messages = [
            {
                role: "system",
                content: "You are an expert plant pathologist. Analyze plant classifications and provide disease diagnosis in JSON format."
            },
            {
                role: "user",
                content: prompt
            }
        ];

        const response = await hf.chatCompletion({
            model: "mistralai/Mistral-7B-Instruct-v0.2",
            messages: messages,
            max_tokens: 400,
            temperature: 0.3,
        });

        let text = response.choices[0]?.message?.content?.trim() || "";

        // Extract JSON from response
        const jsonMatch = text.match(/\{[\s\S]*\}/);
        if (!jsonMatch) {
            // Fallback response if JSON parsing fails
            return {
                disease: imageDescription.includes("healthy") ? "Healthy" : "Potential Issue Detected",
                confidence: confidence,
                description: `The plant appears to be ${imageDescription}. For accurate diagnosis, ensure the image clearly shows any affected areas with good lighting.`,
                treatment: ["Take a clearer, well-lit photo", "Focus on affected areas", "Try again with better image quality"]
            };
        }

        const parsed = JSON.parse(jsonMatch[0]);

        // Validate structure
        if (!parsed.disease || typeof parsed.confidence !== 'number' || !parsed.description || !Array.isArray(parsed.treatment)) {
            throw new Error("Invalid response structure");
        }

        return parsed;

    } catch (error: any) {
        console.error("Hugging Face Image Analysis Error:", error);

        if (error.message?.includes("rate limit") || error.status === 429) {
            return {
                error: "Rate limit reached. Please wait a moment or add your Hugging Face API key in Settings."
            };
        }

        const isAuthError =
            error.status === 401 ||
            error.status === 403;

        if (isAuthError) {
            return { error: "Authentication failed. Please verify your Hugging Face API Key." };
        }

        if (error.status === 503) {
            return { error: "Model is loading. Please try again in 10-20 seconds." };
        }

        return { error: error.message || "An unexpected error occurred during image analysis." };
    }
}
